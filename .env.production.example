APP_NAME="Recharge Platform"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=recharge_software
DB_USERNAME=recharge_app
DB_PASSWORD="your-strong-password"

# Read replica (set to replica IP in production)
DB_READ_HOST=10.0.0.2
DB_READ_USERNAME=recharge_readonly
DB_READ_PASSWORD="your-strong-password"

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=your-redis-password
REDIS_PORT=6379

# Switch both to redis for production
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Dedicated queue for recharge jobs (workers listen on 'recharges')
REDIS_QUEUE=recharges
REDIS_QUEUE_RETRY_AFTER=150

# ── Recharge platform ─────────────────────────────────────────────────────
RECHARGE_MAX_RETRIES=3
RECHARGE_QUEUE=recharges
RECHARGE_CALLBACK_SECRET=your-hmac-secret-min-32-chars
RECHARGE_DEDUP_WINDOW=60

SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=redis
